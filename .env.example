# ─── Singlife — AI Assistant Configuration ────────────────────────────────────
# Copy this file to .env and fill in your values.
# cp .env.example .env

# REQUIRED — Your Anthropic API key (same key as before, no new key needed)
# Get or view yours at: https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=false
PORT=5001
SECRET_KEY=change-this-in-production

# CORS (comma-separated origins)
ALLOWED_ORIGINS=http://localhost:5001,http://127.0.0.1:5001
