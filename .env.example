# Singlife AI Ops — config
# copy this to backend/.env and fill in your values

# required — get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-your-key-here

# model config (defaults are fine for most cases)
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=4096

# flask
FLASK_ENV=development
FLASK_DEBUG=false
PORT=5003

# cors
ALLOWED_ORIGINS=http://localhost:5003,http://127.0.0.1:5003
