{
  "sop_id": "SOP-NBIG-STP-001",
  "version": "Sprint 2 — 2026-03-30",
  "description": "New Business Pre-Issue Checks & Decisioning rules config",

  "channel_gating": {
    "QnB": {
      "1A": "N", "1B": "N", "1C": "N",
      "2A": "N",
      "3A": "N",
      "4A": "Y", "4B": "Y", "4C": "N",
      "5A": "N", "5B": "N", "5C": "Y", "5C_name": "Y", "5D": "N",
      "6A": "NA", "6E": "NA", "6F": "NA", "6G": "NA", "6H": "NA", "6I": "NA",
      "7A": "Y", "7B": "Y", "7C": "N",
      "8A": "Y", "8B": "Y", "8C": "Y", "8D": "Y", "8E": "Y", "8F": "Y", "8G": "Y", "8H": "N",
      "9A": "Y"
    },
    "EzSub": {
      "1A": "Y", "1B": "Y", "1C": "Y",
      "2A": "Y",
      "3A": "Y",
      "4A": "Y", "4B": "Y", "4C": "Y",
      "5A": "N", "5B": "N", "5C": "Y", "5C_name": "Y", "5D": "N",
      "6A": "NA", "6E": "NA", "6F": "NA", "6G": "NA", "6H": "NA", "6I": "NA",
      "7A": "Y", "7B": "Y", "7C": "N",
      "8A": "Y", "8B": "Y", "8C": "Y", "8D": "Y", "8E": "Y", "8F": "Y", "8G": "Y", "8H": "N",
      "9A": "Y"
    },
    "Hardcopy": {
      "1A": "Y", "1B": "Y", "1C": "Y",
      "2A": "Y",
      "3A": "Y",
      "4A": "Y", "4B": "Y", "4C": "Y",
      "5A": "N", "5B": "N", "5C": "Y", "5C_name": "Y", "5D": "N",
      "6A": "NA", "6E": "NA", "6F": "NA", "6G": "NA", "6H": "NA", "6I": "NA",
      "7A": "Y", "7B": "Y", "7C": "N",
      "8A": "Y", "8B": "Y", "8C": "Y", "8D": "Y", "8E": "Y", "8F": "Y", "8G": "Y", "8H": "N",
      "9A": "Y"
    }
  },

  "steps": {
    "1A": {
      "description": "Open Identity Document on FileNet",
      "category": "Open Documents",
      "rule": "document_exists",
      "document": "identity_doc",
      "truthy_values": ["true", "yes", "1", "y", "exists"],
      "pass_condition": "Identity document exists in FileNet",
      "fail_impact": "Further Requirements",
      "fail_recommended_action": "Create follow-up for missing document"
    },
    "1B": {
      "description": "Open Benefit Illustration on FileNet",
      "category": "Open Documents",
      "rule": "document_exists",
      "document": "benefit_illustration",
      "truthy_values": ["true", "yes", "1", "y", "exists"],
      "pass_condition": "Benefit Illustration exists and is readable",
      "fail_impact": "Further Requirements",
      "fail_recommended_action": "Create follow-up for missing document"
    },
    "1C": {
      "description": "Open Application Form on DotSphere",
      "category": "Open Documents",
      "rule": "document_exists",
      "document": "application_form",
      "truthy_values": ["true", "yes", "1", "y", "exists"],
      "pass_condition": "Application Form exists for comparison",
      "fail_impact": "Further Requirements",
      "fail_recommended_action": "Create follow-up for missing document"
    },
    "2A": {
      "description": "Check MyInfo Consent Form Timestamp validity",
      "category": "Document Checks",
      "rule": "consent_timestamp",
      "max_age_days": 365,
      "pass_condition": "MyInfo consent timestamp within 1 year of application date",
      "fail_impact": "Further Requirements",
      "fail_recommended_action": "Request new MyInfo consent from customer",
      "missing_recommended_action": "Verify MyInfo consent form in FileNet"
    },
    "3A": {
      "description": "Search client on L400 using NRIC/License",
      "category": "Client Number Search",
      "rule": "client_search_nric",
      "pass_condition": "Exactly 1 client record found by NRIC",
      "fail_impact": "Refer Ops",
      "fail_recommended_action": "Verify client identity — possible wrong NRIC entry"
    },
    "4A": {
      "description": "Search client by Surname + Given Name",
      "category": "Duplicate Client Checks",
      "rule": "client_record_found",
      "pass_condition": "Client record exists on L400",
      "fail_impact": "Refer Ops"
    },
    "4B": {
      "description": "Check DOB and Sex vs Application Form",
      "category": "Duplicate Client Checks",
      "rule": "field_match",
      "fields": ["dob", "sex"],
      "field_mapping": {
        "dob": { "sub_key": "sub_dob", "l400_key": "l400_dob", "is_date": true },
        "sex": { "sub_key": "sub_sex", "l400_key": "l400_sex", "is_date": false }
      },
      "pass_condition": "Both DOB and Sex match between L400 and application",
      "fail_impact": "Refer Ops",
      "fail_recommended_action": "Flag for human verification — do not auto-correct"
    },
    "5C": {
      "description": "Validate key client fields (Sex, Nationality, NRIC, DOB)",
      "category": "Client Information Checks",
      "rule": "field_match",
      "fields": ["sex", "nationality", "nric", "dob"],
      "field_mapping": {
        "dob": { "sub_key": "sub_dob", "l400_key": "l400_dob", "is_date": true },
        "sex": { "sub_key": "sub_sex", "l400_key": "l400_sex", "is_date": false },
        "nationality": { "sub_key": "sub_nationality", "l400_key": "l400_nationality", "is_date": false },
        "nric": { "sub_key": "sub_nric", "l400_key": "l400_nric", "is_date": false }
      },
      "pass_condition": "All key fields match between L400 and application",
      "fail_impact": "Further Requirements",
      "fail_recommended_action": "Flag for human verification — do not auto-correct"
    },
    "5C_name": {
      "description": "Check client name sequence (Surname, Given Name)",
      "category": "Client Information Checks",
      "rule": "field_match",
      "fields": ["name"],
      "field_mapping": {
        "name": { "type": "name_match" }
      },
      "pass_condition": "Name sequence matches between submission and L400",
      "fail_impact": "Refer Ops",
      "fail_recommended_action": "Ops to check name sequence based on race — Chinese: surname+given, non-Chinese: given+surname. Adjust in L400 to match NRIC."
    },
    "7B": {
      "description": "Check if all follow-ups are R (Resolved)",
      "category": "Follow-Up Code Checks",
      "rule": "all_followups_resolved",
      "resolved_status": "R",
      "pass_condition": "All follow-up codes have status R",
      "fail_impact": "Further Requirements",
      "fail_recommended_action": "Resolve outstanding follow-ups before locking case"
    },
    "8B": {
      "description": "Check ANB and Total Aggregate SA",
      "category": "Jet Underwriting",
      "rule": "threshold_check",
      "thresholds": [
        { "condition": "sa > 6000", "result": "Refer UW", "label": "SA exceeds $6,000 — Refer regardless of ANB" },
        { "condition": "sa <= 6000 and anb >= 18 and anb <= 30", "result": "Continue", "label": "SA <= $6,000 and ANB 18-30 — Continue" },
        { "condition": "sa <= 5000 and anb >= 31", "result": "Continue", "label": "SA <= $5,000 and ANB >= 31 — Continue" },
        { "condition": "sa <= 6000 and (anb < 18 or anb > 30)", "result": "Refer UW", "label": "SA <= $6,000 but ANB outside 18-30 — Refer" }
      ],
      "pass_condition": "SA within Jet UW STP limits for ANB band",
      "fail_impact": "Refer UW",
      "missing_recommended_action": "Check L400 Client UW Inquiries screen"
    },
    "8C": {
      "description": "Check UW Sub-std",
      "category": "Jet Underwriting",
      "rule": "uw_indicator",
      "field": "uw_sub_std",
      "label": "UW Sub-std",
      "pass_values": ["N", "A", ""],
      "fail_values": ["Y", "M"],
      "fail_impact": "Refer UW"
    },
    "8D": {
      "description": "Check Decline",
      "category": "Jet Underwriting",
      "rule": "uw_indicator",
      "field": "decline",
      "label": "Decline",
      "pass_values": ["N", "A", ""],
      "fail_values": ["Y", "M"],
      "fail_impact": "Refer UW"
    },
    "8E": {
      "description": "Check Postpone",
      "category": "Jet Underwriting",
      "rule": "uw_indicator",
      "field": "postpone",
      "label": "Postpone",
      "pass_values": ["N", "A", ""],
      "fail_values": ["Y", "M"],
      "fail_impact": "Refer UW"
    },
    "8F": {
      "description": "Check Claim Ind",
      "category": "Jet Underwriting",
      "rule": "uw_indicator",
      "field": "claim_ind",
      "label": "Claim Ind",
      "pass_values": ["N", "A", ""],
      "fail_values": ["Y", "M"],
      "fail_impact": "Refer UW"
    },
    "8G": {
      "description": "Check if only Claim Ind = Y (all others N)",
      "category": "Jet Underwriting",
      "rule": "rcs_trigger",
      "trigger_field": "claim_ind",
      "trigger_value": "y",
      "other_fields": ["uw_sub_std", "decline", "postpone"],
      "clear_values": ["n", "a", ""],
      "pass_impact": "RCS Required",
      "pass_recommended_action": "Perform RCS checks on ICD codes",
      "pass_condition": "Only Claim Ind flagged — RCS check required",
      "fail_impact": "Refer UW"
    }
  },

  "decision_mapping": {
    "Standard": {
      "condition": "All applicable steps Pass and no outstanding follow-ups",
      "decision_label": "Approve",
      "workflow_action": "Decision Locked with No Further Requirements",
      "ops_outcome_detail": "All checks passed. Lock decision with no further requirements.",
      "human_review": false,
      "dotsphere_steps": [
        "Go to Underwriting Decision Update screen on L400",
        "Set Proposal Accepted = Y",
        "Set Print Acceptance Letter = B",
        "Go to DotSphere",
        "Select Decision: Decision Locked with No Further Requirements"
      ]
    },
    "StandardWithFurtherRequirements": {
      "condition": "Any doc missing OR PF not all R OR unresolved data mismatch",
      "decision_label": "Block",
      "workflow_action": "Trigger follow-up / pending requirements",
      "ops_outcome_detail": "Keep case pending; request/resolve outstanding follow-ups before locking decision.",
      "human_review": false,
      "dotsphere_steps": [
        "Go to Proposal Follow-ups screen on L400",
        "Set Print Letter = B",
        "Go to DotSphere",
        "Select: All Data Verified? + Mandatory PF/BI/FFF Missing Info? + Initial/Continue Pending Requirement with Original NTU days"
      ]
    },
    "ReferToUW": {
      "condition": "Any UW indicator triggers OR RCS result Refer",
      "decision_label": "Refer UW",
      "workflow_action": "Underwriting Review",
      "ops_outcome_detail": "Refer case to underwriter for review.",
      "human_review": true,
      "dotsphere_steps": [
        "Go to DotSphere",
        "Select Decision: Underwriting Review?"
      ]
    },
    "ReferToOps": {
      "condition": "Name sequence mismatch, NRIC search anomaly, or duplicate client requiring Ops resolution (per May's clarifications #4 and #9)",
      "decision_label": "Refer Ops",
      "workflow_action": "Ops Review",
      "ops_outcome_detail": "Refer case to Ops for client-record investigation: name sequence (race-based), NRIC verification, or duplicate client merge/create.",
      "human_review": true,
      "dotsphere_steps": [
        "Go to L400 Client Records screen",
        "For name mismatch: adjust name sequence per race (Chinese: surname+given, non-Chinese: given+surname) so full-name string matches NRIC",
        "For NRIC anomaly (0 or >1 results): investigate existing policies tagged to different client records; merge if duplicate or create new client_id if none",
        "Go to DotSphere",
        "Select Decision: Refer to Ops"
      ]
    },
    "TriggerGNS": {
      "condition": "C09 follow-up code outstanding or compliance hit",
      "decision_label": "Trigger GNS",
      "workflow_action": "Compliance workflow",
      "ops_outcome_detail": "Trigger GNS / Compliance workflow for screening.",
      "human_review": true,
      "dotsphere_steps": [
        "Go to DotSphere",
        "Select Decision: Trigger GNS review"
      ]
    },
    "Withdrawal": {
      "condition": "Withdrawal request received",
      "decision_label": "Withdrawal",
      "workflow_action": "Close case",
      "ops_outcome_detail": "Close case — withdrawal request received.",
      "human_review": false,
      "dotsphere_steps": [
        "Go to Contract Issue screen on L400",
        "Enter Contract Number",
        "Action = B",
        "Reason = N001",
        "Go to DotSphere",
        "Select Decision: Withdrawal Request Received"
      ]
    }
  },

  "decision_logic": {
    "followup_step_id": "7B",
    "compliance_trigger_codes": ["C09"],
    "fail_statuses": ["Fail", "Refer UW", "Refer Ops"],
    "decision_priority": [
      {
        "key": "ReferToUW",
        "condition": "any_step_has_impact",
        "impact_value": "Refer UW",
        "also_check_status": "Refer UW",
        "additional_impacts": ["RCS Required"]
      },
      {
        "key": "ReferToOps",
        "condition": "any_step_has_impact",
        "impact_value": "Refer Ops",
        "also_check_status": "Refer Ops"
      },
      {
        "key": "TriggerGNS",
        "condition": "compliance_code_outstanding"
      },
      {
        "key": "StandardWithFurtherRequirements",
        "condition": "any_step_has_impact",
        "impact_value": "Further Requirements"
      },
      {
        "key": "Standard",
        "condition": "default"
      }
    ],
    "automation_rule": "all_steps_pass_and_no_failures",
    "automation_trigger_by_decision": {
      "_description": "automation_trigger=Yes means Power Automate can handle the next workflow action. It does NOT mean auto-approve.",
      "Standard": "Yes",
      "StandardWithFurtherRequirements": "Yes",
      "Withdrawal": "Yes",
      "ReferToUW": "No",
      "ReferToOps": "No",
      "TriggerGNS": "No"
    }
  },

  "followup_codes_critical": {
    "CSL": { "category": "EYA/EYB", "meaning": "Basic CSL Plan Status check" },
    "F45": { "category": "Premium", "meaning": "PF-Premium differ from PI (premium mismatch)" },
    "C09": { "category": "Compliance", "meaning": "Compliance GNS Rescreening" },
    "AT3": { "category": "DVM", "meaning": "DVM Agent Tier T3" },
    "GNS": { "category": "Compliance", "meaning": "Global Naming Screening" }
  }
}
